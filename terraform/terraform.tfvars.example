# Copy this file to terraform.tfvars and fill in your own values.
# terraform.tfvars should NOT be committed to GitHub if it contains anything sensitive.

aws_region    = "eu-west-1"
instance_type = "t2.micro"
key_name      = "b9is121-keypair"       # must already exist in your AWS account
my_ip         = "203.0.113.10/32"        # replace with YOUR public IP (check whatismyip.com)
